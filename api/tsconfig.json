{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "baseUrl": "..",
    "paths": {
      "@/*": ["./backend/src/*"]
    }
  },
  "include": ["./**/*", "../backend/src/**/*"],
  "exclude": ["../node_modules", "../backend/dist", "../backend/src/tests/**/*"]
}
