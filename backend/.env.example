# ─────────────────────────────────────────────────────────────────────────────
# AuraBot Backend — Variáveis de Ambiente
# Copie: cp backend/.env.example backend/.env
# Depois preencha cada valor conforme as instruções abaixo
# ─────────────────────────────────────────────────────────────────────────────

# ─── Servidor ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
ALLOWED_ORIGINS=http://localhost:5173

# ─── Banco de dados ─────────────────────────────────────────────────────────
# Com Docker (padrão): não precisa mudar
# Sem Docker: ajuste usuário/senha/host/banco para sua instalação local
DATABASE_URL=file:./aurabot.db

# ─── JWT ────────────────────────────────────────────────────────────────────
# Gere cada um com:
#   node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
# Use strings DIFERENTES para cada variável. Não compartilhe esses valores.
JWT_SECRET=SUBSTITUA-POR-STRING-ALEATORIA-LONGA-64-BYTES
JWT_REFRESH_SECRET=SUBSTITUA-POR-OUTRA-STRING-ALEATORIA-LONGA-64-BYTES

# ─── Spotify API ────────────────────────────────────────────────────────────
# 1. Acesse: https://developer.spotify.com/dashboard
# 2. Crie um app → copie Client ID e Client Secret
SPOTIFY_CLIENT_ID=seu_spotify_client_id
SPOTIFY_CLIENT_SECRET=seu_spotify_client_secret

# ─── YouTube Data API v3 ────────────────────────────────────────────────────
# 1. Acesse: https://console.cloud.google.com
# 2. Crie projeto → Ative "YouTube Data API v3" → Credenciais → Chave de API
YOUTUBE_API_KEY=sua_youtube_api_key

# ─── OpenAI (Whisper STT + TTS) ─────────────────────────────────────────────
# 1. Acesse: https://platform.openai.com/api-keys
# 2. Create new secret key
OPENAI_API_KEY=sk-seu_openai_api_key

# ─── Email (SMTP para recuperação de senha) ─────────────────────────────────
# Gmail:
#   1. Ative verificação em duas etapas na conta Google
#   2. Segurança → Senhas de app → gere uma senha para "AuraBot"
#   3. Use a senha gerada (16 chars) em SMTP_PASS
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu@gmail.com
SMTP_PASS=sua_senha_de_app_sem_espacos
SMTP_FROM=AuraBot <noreply@aurabot.app>

# ─── Frontend ────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# URL pública do próprio backend (usada como redirect_uri no OAuth Spotify)
BACKEND_URL=http://localhost:3001

# ─── Bot Token (Discord / Desktop) ──────────────────────────────────────────
# String aleatória compartilhada entre o backend e o bot Discord/Desktop.
# O bot envia esse token no header Authorization para se autenticar na API.
# DEVE ser IGUAL ao AURABOT_BOT_TOKEN em discord/.env
# Gere com:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
AURABOT_BOT_TOKEN=gere_uma_string_aleatoria_e_use_o_mesmo_valor_no_discord

# ─── Logs ────────────────────────────────────────────────────────────────────
LOG_LEVEL=debug
