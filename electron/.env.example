# AuraBot — Configuração do aplicativo
# 
# Em produção, este arquivo fica em:
#   Windows: %APPDATA%\AuraBot\.env
#   macOS:   ~/Library/Application Support/AuraBot/.env
#   Linux:   ~/.config/AuraBot/.env
#
# Copie este arquivo para o caminho correto e preencha os valores.

# ─── Banco de dados (gerado automaticamente pelo app) ─────────────────────────
# Não é necessário alterar — o app cria o banco SQLite automaticamente
DATABASE_URL=file:./aurabot.db

# ─── APIs externas ────────────────────────────────────────────────────────────
# Spotify: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=seu_spotify_client_id
SPOTIFY_CLIENT_SECRET=seu_spotify_client_secret

# YouTube: https://console.cloud.google.com
YOUTUBE_API_KEY=sua_youtube_api_key

# OpenAI (voz): https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-sua_chave_openai

# ─── Email (recuperação de senha) ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu@gmail.com
SMTP_PASS=sua_senha_de_app
SMTP_FROM=AuraBot <noreply@aurabot.app>

# ─── Segurança (gerado automaticamente pelo app) ──────────────────────────────
# Não altere estes valores após o primeiro uso
JWT_SECRET=
JWT_REFRESH_SECRET=
