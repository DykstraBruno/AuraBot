{
  "name": "aurabot-desktop",
  "version": "1.0.0",
  "description": "AuraBot \u2014 Bot de m\u00fasica controlado por voz",
  "main": "src/main.js",
  "author": "AuraBot Contributors",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "electron .",
    "build:win": "electron-builder --win --x64",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "dependencies": {
    "electron-is-dev": "^2.0.0"
  },
  "devDependencies": {
    "electron": "28.0.0",
    "electron-builder": "24.9.1"
  },
  "build": {
    "appId": "app.aurabot.desktop",
    "productName": "AuraBot",
    "copyright": "Copyright \u00a9 2025 AuraBot Contributors",
    "files": [
      "src/**/*",
      "assets/**/*"
    ],
    "extraResources": [
      {
        "from": "../backend/dist",
        "to": "backend/dist",
        "filter": [
          "**/*.js",
          "**/*.json"
        ]
      },
      {
        "from": "../backend/node_modules",
        "to": "backend/node_modules",
        "filter": [
          "**/*",
          "!**/*.ts",
          "!**/test/**",
          "!**/tests/**",
          "!**/*.md"
        ]
      },
      {
        "from": "../backend/prisma",
        "to": "backend/prisma",
        "filter": [
          "schema.prisma",
          "migrations/**"
        ]
      },
      {
        "from": "../frontend/dist",
        "to": "frontend/dist"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AuraBot",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "language": "1046"
    },
    "publish": null
  }
}