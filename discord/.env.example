# ─── Discord ─────────────────────────────────────────────────────────────────
# Obtenha em: discord.com/developers/applications → seu app → Bot → Token
DISCORD_TOKEN=seu_bot_token_aqui

# Obtenha em: discord.com/developers/applications → seu app → Application ID
DISCORD_CLIENT_ID=seu_application_id

# ID do servidor Discord para dev (acelera deploy dos comandos)
# No Discord: clique com botão direito no servidor → Copiar ID do servidor
# Deixe em branco para deploy global (demora até 1h para propagar)
DISCORD_GUILD_ID=id_do_seu_servidor_de_dev

# ─── AuraBot API ─────────────────────────────────────────────────────────────
AURABOT_API_URL=http://localhost:3001/api

# Token que o bot usa para se autenticar na API.
# DEVE ser o mesmo valor que AURABOT_BOT_TOKEN no backend/.env
# Gere com: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
AURABOT_BOT_TOKEN=gere_uma_string_aleatoria_e_coloque_igual_no_backend

# ─── Configurações ────────────────────────────────────────────────────────────
LOG_LEVEL=info
